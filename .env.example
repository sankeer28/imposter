# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit real keys.

# ── AI word engine (Tier 1 — Groq) ───────────────────────────────────────────
# Free tier: ~14,400 requests/day
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# ── AI word engine (Tier 2 — Ollama Cloud) ───────────────────────────────────
# Free tier, fast
# Get a key: https://ollama.com/settings/api-keys
OLLAMA_API_KEY=

# ── AI word engine (Tier 3 — OpenRouter) ─────────────────────────────────────
# Free tier (gpt-oss-120b:free), slower
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── AI word engine (Tier 4 — Google Gemini) ──────────────────────────────────
# Free tier: 1,500 requests/day (last AI resort before hardcoded fallback)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
